# ─── Square ──────────────────────────────────────────────────────────
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=
NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
# Optional: Square hosted ordering profile (fallback URL)
NEXT_PUBLIC_SQUARE_ORDERING_PROFILE_URL=
# Optional: Separate token for developer role sessions (forces sandbox environment)
# Developers automatically use sandbox regardless of SQUARE_ENVIRONMENT
SQUARE_SANDBOX_ACCESS_TOKEN=

# ─── Twilio ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Square Webhooks (Phase 2) ──────────────────────────────────────
SQUARE_WEBHOOK_SIGNATURE_KEY=

# ─── Outstatic CMS (Phase 2) ────────────────────────────────────────
OUTSTATIC_API_KEY=

# ─── CMS Provider Selection (Phase 8) ───────────────────────────────
# CMS_PROVIDER=outstatic            # or "wordpress"
# CMS_WORDPRESS_URL=                # e.g. https://mysite.com/graphql
# CMS_PREVIEW_SECRET=               # optional — enables draft preview
# CMS_WORDPRESS_USERNAME=           # for draft preview via application passwords
# CMS_WORDPRESS_PASSWORD=           # for draft preview via application passwords

# ─── Dashboard Auth (Phase 3) ───────────────────────────────────────
DASHBOARD_PASSWORD=

# ─── RBAC via Square Team API (Phase 7) ─────────────────────────────
# Email used to look up Square team membership for role assignment.
# Optional - defaults to owner role if unset.
DASHBOARD_ADMIN_EMAIL=
# Comma-separated emails granted the developer role (bypasses Square lookup)
DASHBOARD_DEVELOPER_EMAILS=

# ─── MFA via Twilio SMS (Phase 7) ───────────────────────────────────
# Admin phone for MFA OTP delivery (Twilio-compatible E.164 format)
DASHBOARD_ADMIN_PHONE=
# OTP validity window in seconds (default: 300 = 5 minutes)
MFA_CODE_TTL=300

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=

# ─── Square Loyalty (Phase 6) ───────────────────────────────────────
# From Square Developer Dashboard > Loyalty > Program ID
SQUARE_LOYALTY_PROGRAM_ID=

# ─── Demo Mode (Phase 5) ────────────────────────────────────────────
# Set to "true" to use mock data (no real Square API calls)
NEXT_PUBLIC_DEMO_MODE=false
